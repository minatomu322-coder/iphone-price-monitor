# 利益商品AI（rakuten_finder）のシークレット設定
# このファイルを .env にコピーして値を埋める（.env は .gitignore 済み）

# Discord Webhook（通知先チャンネルの Webhook URL）
DISCORD_WEBHOOK_URL=

# 楽天ウェブサービスのアプリID（https://webservice.rakuten.co.jp/ で無料発行）
RAKUTEN_APP_ID=

# 楽天アフィリエイトID（任意）
RAKUTEN_AFFILIATE_ID=

# DB ファイルのパス（省略時: data/rakuten_finder.sqlite3）
RAKUTEN_FINDER_DB=
